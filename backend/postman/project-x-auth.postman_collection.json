{
  "info": {
    "_postman_id": "8f29df9f-1eb1-468f-aef9-ac2c03939358",
    "name": "Project X Auth APIs",
    "description": "Postman collection for testing the OTP-gated Project X auth flow. Recommended order: Signup Request OTP -> Signup Verify OTP -> Signup Complete -> Login Request OTP -> Login Verify OTP -> Refresh -> Me.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Signup Request OTP",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "if (!pm.collectionVariables.get('userEmail')) {",
                  "  pm.collectionVariables.set('userEmail', 'tester' + Date.now() + '@example.com');",
                  "}",
                  "if (!pm.collectionVariables.get('userPhone')) {",
                  "  var suffix = Date.now().toString().slice(-10);",
                  "  pm.collectionVariables.set('userPhone', '91' + suffix);",
                  "}"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Signup OTP request succeeded', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('signupOtpSessionId', json.otp_session_id || '');",
                  "pm.collectionVariables.set('signupOtp', json.debug_otp || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"phone\": \"{{userPhone}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup/request-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signup",
                "request-otp"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Signup Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Signup OTP verify succeeded', function () {",
                  "  pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('verifiedSignupToken', json.verified_signup_token || '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"otp_session_id\": \"{{signupOtpSessionId}}\",\n  \"phone\": \"{{userPhone}}\",\n  \"otp\": \"{{signupOtp}}\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup/verify-otp",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signup",
                "verify-otp"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Signup Complete",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Signup complete succeeded', function () {",
                  "  pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set('accessToken', json.access_token || '');",
                  "pm.collectionVariables.set('refreshToken', json.refresh_token || '');",
                  "pm.collectionVariables.set('accountId', json.account && json.account.id ? json.account.id : '');",
                  "pm.collectionVariables.set('primaryProfileId', json.account && json.account.primary_profile_id ? json.account.primary_profile_id : '');"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "x-device-name",
                "value": "Postman Desktop"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"verified_signup_token\": \"{{verifiedSignupToken}}\",\n  \"email\": \"{{userEmail}}\",\n  \"full_name\": \"{{fullName}}\",\n  \"date_of_birth\": \"1995-06-15\",\n  \"gender\": \"MALE\",\n  \"pan_number\": \"ABCDE1234F\",\n  \"name_on_pan\": \"{{fullName}}\",\n  \"current_address\": {\n    \"address_line_1\": \"123 Main Street\",\n    \"city\": \"Mumbai\",\n    \"state\": \"Maharashtra\",\n    \"pincode\": \"400001\",\n    \"country\": \"India\"\n  },\n  \"is_same_as_current\": true\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/auth/signup/complete",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "auth",
                "signup",
                "complete"
              ]
            }
          },
          "response": []
        },
