              ]
            }
          },
          "response": []
        },
        {
          "name": "Login Verify OTP",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Login OTP verify succeeded', function () {",
                  "  pm.response.to.have.status(200);",
