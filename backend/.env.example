POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=continuum
CONTINUUM_ENVIRONMENT=local
CONTINUUM_PROJECT_NAME=Project X API
CONTINUUM_API_V1_PREFIX=/api/v1
CONTINUUM_DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/continuum
CONTINUUM_ALLOWED_ORIGINS=http://localhost:3020,http://localhost:3021
CONTINUUM_S3_BUCKET_NAME=continuum-documents-local
CONTINUUM_KMS_KEY_ID=alias/continuum-local
CONTINUUM_LOG_LEVEL=INFO
CONTINUUM_LOG_FORMAT=json
